@using Sandbox;
@using Sandbox.UI;
@inherits Panel
@namespace Sandbox

<VirtualGrid Items=@Effects ItemSize=@(160)>
    <Item Context="item">
        @if (item is PostProcessResource entry)
        {
            var active = Manager?.IsEnabled( entry.ResourcePath ) ?? false;
            var selected = Manager?.SelectedPath == entry.ResourcePath;
            <div class="postprocess-icon @(active ? "active" : "") @(selected ? "selected" : "")"
                 onclick=@(() => OnSelect( entry ))
                 onmouseenter=@(() => Manager?.Preview( entry.ResourcePath ))
                 onmouseleave=@(() => Manager?.Unpreview())>
                <div class="thumb" style="background-image: url(thumb:@entry.ResourcePath)"></div>
                <div class="bottom-bar">
                    <div class="title">@entry.Title</div>
                    <div class="checkbox @(active ? "on" : "")" onclick:stopPropagation="true" @onclick=@(() => OnToggle( entry ))>
                        @(active ? "ON" : "OFF")
                    </div>
                </div>
            </div>
        }
    </Item>
</VirtualGrid>

@code
{
    [Parameter] public PostProcessGroup? Group { get; set; }

    List<PostProcessResource> Effects = [];
    PostProcessManager Manager;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var all = ResourceLibrary.GetAll<PostProcessResource>();
        Effects = ( Group is null
            ? all
            : all.Where( r => r.Group == Group )
        ).ToList();

        Manager ??= Game.ActiveScene.GetSystem<PostProcessManager>();
    }

    void OnSelect( PostProcessResource entry )
    {
        Manager?.Select( entry.ResourcePath );
        StateHasChanged();
    }

    void OnToggle( PostProcessResource entry )
    {
        Manager?.Toggle( entry.ResourcePath );
        StateHasChanged();
    }

    protected override int BuildHash() =>
        HashCode.Combine( Effects.Count, Manager?.SelectedPath, Manager?.IsEnabled( Manager?.SelectedPath ?? "" ) );

    public override void Tick()
    {
        base.Tick();
        StateHasChanged();
    }
}
