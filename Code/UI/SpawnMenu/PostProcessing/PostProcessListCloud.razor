@using Sandbox;
@using Sandbox.UI;
@inherits Panel
@namespace Sandbox

@if ( LastResult is null )
{
    return;
}

<SpawnMenuContent>

    <Header>
        <SpawnMenuToolbar>
            <Left>
                <TextEntry Placeholder="Search..." class="filter" Value:bind=@Filter />
            </Left>
            <Right>
                <DropDown Value:bind=@SortOrder />
            </Right>
        </SpawnMenuToolbar>
    </Header>

    <Body>
        @if ( !FilteredPackages.Any() )
        {
            <p>No post process effects found.</p>
        }
        else
        {
        <VirtualGrid Items=@FilteredPackages ItemSize=@(160)>
                <Item Context="pkg">
                    @if (pkg is Package entry)
                    {
                        var mounted = MountedResources.GetValueOrDefault( entry.FullIdent );
                        var resourcePath = mounted?.ResourcePath;
                        var active = resourcePath != null && (Manager?.IsEnabled( resourcePath ) ?? false);
                        var selected = resourcePath != null && Manager?.SelectedPath == resourcePath;
                        var mounting = _mounting.Contains( entry.FullIdent );
                        var thumbUrl = mounted?.Icon != null ? $"thumb:{mounted.Icon.ResourcePath}" : entry.Thumb;
                        <div class="postprocess-icon @(active ? "active" : "") @(selected ? "selected" : "")"
                             onclick=@(() => OnSelect( entry ))
                             onmouseenter=@(() => { if ( resourcePath != null ) Manager?.Preview( resourcePath ); })
                             onmouseleave=@(() => Manager?.Unpreview())>
                            <div class="thumb" style="background-image: url(@thumbUrl)"></div>
                            <div class="bottom-bar">
                                <div class="title">@entry.Title</div>
                                <div class="checkbox @(active ? "on" : "") @(mounting ? "loading" : "")"
                                     onclick:stopPropagation="true" @onclick=@(() => OnToggle( entry ))>
                                    @(mounting ? "..." : active ? "ON" : "OFF")
                                </div>
                            </div>
                        </div>
                    }
                </Item>
            </VirtualGrid>
        }
    </Body>

</SpawnMenuContent>

@code
{
    private string Filter
    {
        get;
        set { field = value; Rebuild(); }
    }

    public PackageSortMode SortOrder
    {
        get;
        set { field = value; Rebuild(); }
    }

    Package.FindResult LastResult;
    IEnumerable<Package> FilteredPackages => LastResult?.Packages.Where( p => p.TypeName == "spp" ) ?? [];
    Dictionary<string, PostProcessResource> MountedResources = new();
    HashSet<string> _mounting = new();
    PostProcessManager Manager;

    protected override void OnParametersSet()
    {
        SortOrder = PackageSortMode.Newest;
        Manager ??= Game.ActiveScene.GetSystem<PostProcessManager>();
        Rebuild();
    }

    async void Rebuild()
    {
        var query = $"sort:{SortOrder.ToIdentifier()}";
        if ( !string.IsNullOrEmpty( Filter ) ) query += $" {Filter}";

        LastResult = await Package.FindAsync( query );
        StateHasChanged();
    }

    async Task<PostProcessResource> MountAndGet( Package pkg )
    {
        if ( MountedResources.TryGetValue( pkg.FullIdent, out var cached ) )
            return cached;

        _mounting.Add( pkg.FullIdent );
        StateHasChanged();

        var resource = await ResourceLibrary.LoadAsync<PostProcessResource>( pkg.FullIdent );
        resource ??= await Cloud.Load<PostProcessResource>( pkg.FullIdent, true );

        _mounting.Remove( pkg.FullIdent );

        if ( resource != null )
            MountedResources[pkg.FullIdent] = resource;
        else
            Log.Warning( $"[PostProcess] Could not load .spp from {pkg.FullIdent}" );

        StateHasChanged();
        return resource;
    }

    async void OnSelect( Package pkg )
    {
        var resource = await MountAndGet( pkg );
        if ( resource is null ) return;
        Manager?.Select( resource.ResourcePath );
        StateHasChanged();
    }

    async void OnToggle( Package pkg )
    {
        var resource = await MountAndGet( pkg );
        if ( resource is null ) return;
        Manager?.Toggle( resource.ResourcePath );
        StateHasChanged();
    }
}
